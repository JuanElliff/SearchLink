# Base URL del backend Spring Boot.
# Si no se define, el cliente HTTP usa http://localhost:8080 por defecto.
VITE_API_BASE_URL=http://localhost:8080

# Firebase Web SDK — valores del proyecto en Firebase Console → Configuración del proyecto.
# Estos valores son públicos (aparecen en el bundle JS del cliente).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# VAPID key para Web Push — Firebase Console → Cloud Messaging → Certificados web push.
VITE_FIREBASE_VAPID_KEY=
